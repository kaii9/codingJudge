API_ADDR=:8080
JUDGE_WORKDIR=/tmp/codingjudge-sandbox
WORKER_CONCURRENCY=1
JUDGE_LEASE_DURATION=30s
JUDGE_HEARTBEAT_INTERVAL=10s
JUDGE_MAX_ATTEMPTS=3
WORKER_SHUTDOWN_GRACE=30s

# Optional. Leave empty to use per-language default images.
JUDGE_IMAGE=

# Compose services
DATABASE_URL=postgres://codingjudge:codingjudge@postgres:5432/codingjudge?sslmode=disable
REDIS_ADDR=redis:6379
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
